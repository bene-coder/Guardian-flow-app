# Copy this file to `.env` and fill in your values.
# Anything here is read at build-time by Expo. The runtime backend URL is
# also user-configurable from the in-app Settings screen and stored in
# SecureStore — that one wins over this.

# Default backend URL exposed to the app on first launch.
# For Android emulator, use 10.0.2.2 to reach your dev machine's localhost:3000.
EXPO_PUBLIC_BACKEND_URL=http://10.0.2.2:3000

# Google Maps SDK key (Android + iOS). Leave blank for local dev — the map
# will fall back to a styled placeholder so the rest of the UI is still demoable.
GOOGLE_MAPS_API_KEY=
